@{
    ViewData["Title"] = "Guía de Simulación";
    int idSession = ViewBag.IdSession;
    int fase = ViewBag.FaseActual;
}

<div class="container py-5">

    <!-- HERO -->
    <div class="text-center mb-5">
        <h1 class="display-4 fw-bold">Simulación de Marketing Estratégico</h1>
        <p class="lead text-muted mt-3">
            Enfréntate a decisiones reales y desarrolla tu criterio como consultor.
        </p>
    </div>

    <!-- FRASE -->
    <div class="row justify-content-center mb-5">
        <div class="col-md-8">
            <div class="card border-0 shadow-sm p-4 bg-light">
                <p class="mb-0 text-center fst-italic text-muted">
                    "Estás por iniciar un entorno de aprendizaje dinámico donde cada elección cuenta.
                    Analiza, evalúa y decide con criterio estratégico."
                </p>
            </div>
        </div>
    </div>

    <!-- INSTRUCCIONES -->
    <div class="row justify-content-center mb-5">
        <div class="col-md-8">

            <div class="card shadow-lg border-0">

                <div class="card-body p-4">

                    <h5 class="text-primary fw-bold mb-3 text-center">
                        📘 ¿Cómo funciona la simulación?
                    </h5>

                    <ul class="list-group list-group-flush">
                        <li class="list-group-item">
                            🧩 Cada fase presenta un desafío basado en un caso real.
                        </li>
                        <li class="list-group-item">
                            ⚠️ Las decisiones son <strong>irreversibles</strong>.
                        </li>
                        <li class="list-group-item">
                            💬 Recibirás retroalimentación después de cada elección.
                        </li>
                        <li class="list-group-item">
                            🎯 Tu puntaje final se calculará al completar todas las fases.
                        </li>
                    </ul>

                </div>

            </div>

        </div>
    </div>

    <!-- PROGRESO -->
    <div class="row justify-content-center mb-5">
        <div class="col-md-6 text-center">

            <div class="card border-0 shadow-sm p-3">
                <small class="text-muted">Estado actual</small>
                <h5 class="fw-bold">Fase @fase</h5>

                <div class="progress mt-3" style="height: 10px;">
                    <div class="progress-bar"
                         role="progressbar"
                         style="width: @(fase * 10)%;">
                    </div>
                </div>

            </div>

        </div>
    </div>

    <!-- BOTÓN -->
    <div class="text-center">
        @* Si la fase es 0, forzamos a que empiece en la 1 *@
        <a href="/Simulacion/Jugar?idSession=@idSession&fase=@(fase == 0 ? 1 : fase)"
           class="btn btn-primary btn-lg px-5 py-3 shadow">
            🚀 Comenzar Simulación
        </a>
    </div>

</div>