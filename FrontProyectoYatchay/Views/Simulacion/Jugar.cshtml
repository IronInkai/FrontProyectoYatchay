@model FrontProyectoYatchay.Models.SimulacionViewModel

<div class="container py-5">

    <!-- HEADER -->
    <div class="mb-4 text-center">
        <h6 class="text-muted text-uppercase">Fase @Model.Fase</h6>
        <h2 class="fw-bold">@Model.Titulo</h2>
    </div>

    <!-- PROGRESO -->
    <div class="mb-5">
        <div class="progress" style="height: 10px;">
            <div class="progress-bar" style="width: @(Model.Fase * 10)%"></div>
        </div>
    </div>

    <!-- CONTENIDO -->
    <div class="card shadow-sm border-0 mb-5">
        <div class="card-body p-4">
            <p class="lead text-muted mb-3">
                Analiza la situación:
            </p>
            <p class="fs-5">@Model.Contenido</p>
        </div>
    </div>

    <!-- FORM -->
    <form asp-action="EnviarDecision" asp-controller="Simulacion" method="post" id="formDecision">

        <input type="hidden" name="IdSession" value="@Model.IdSession" />
        <input type="hidden" name="IdContent" value="@Model.IdContent" />
        <input type="hidden" name="FaseActual" value="@Model.IdContent" />
    

        <!-- OPCIONES COMO CARDS -->
        <div class="row g-4">

            @foreach (var opcion in Model.ListadoOpciones)
            {
                <div class="col-md-6 mb-3">
                    @* IMPORTANTE: Usa el nombre exacto de la propiedad del ID en tu ViewModel (ej. IdOption) *@
                    <div class="card opcion-card h-100 shadow-sm border-2"
                         onclick="seleccionarOpcion(@opcion.Id, this)"
                         style="cursor: pointer;">
                        <div class="card-body">
                            <p class="card-text">@opcion.Texto</p>
                        </div>
                    </div>
                </div>
            }

        </div>

        <!-- INPUT HIDDEN -->
        <input type="hidden" name="OpcionElegida" id="opcionElegida" value="0" />

        <!-- BOTÓN -->
        <div class="text-center mt-5">
            <button type="submit" class="btn btn-primary btn-lg px-5" id="btnEnviar" disabled>
                Confirmar decisión
            </button>
        </div>

    </form>

</div>