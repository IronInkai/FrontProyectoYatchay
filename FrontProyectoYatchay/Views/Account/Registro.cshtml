@model FrontProyectoYatchay.Models.RegistroViewModel

@{
    ViewData["Title"] = "Registro";
}

<h1>Registro</h1>

<h4>RegistroViewModel</h4>
<hr />
<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow">
                <div class="card-body">
                    <h2 class="text-center">Crear Cuenta</h2>
                    <form asp-action="Registro" method="post">
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label>Nombre</label>
                                <input asp-for="Nombre" class="form-control" />
                                <span asp-validation-for="Nombre" class="text-danger"></span>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label>Apellido</label>
                                <input asp-for="Apellido" class="form-control" />
                                <span asp-validation-for="Apellido" class="text-danger"></span>
                            </div>
                        </div>
                        <div class="mb-3">
                            <label>Correo Institucional (Cibertec)</label>
                            <input asp-for="Correo" class="form-control" placeholder="i2022...@@cibertec.edu.pe" />
                            <span asp-validation-for="Correo" class="text-danger"></span>
                        </div>
                        <div class="mb-3">
                            <label>DNI</label>
                            <input asp-for="DNI" class="form-control" />
                            <span asp-validation-for="DNI" class="text-danger"></span>
                        </div>
                        <div class="mb-3">
                            <label>Contraseña</label>
                            <input asp-for="Contrasena" type="password" class="form-control" />
                            <span asp-validation-for="Contrasena" class="text-danger"></span>
                        </div>
                        <button type="submit" class="btn btn-success w-100">Registrarse</button>
                    </form>
                    <div class="mt-3 text-center">
                        <a asp-action="Login">¿Ya tienes cuenta? Inicia sesión</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div>
    <a asp-action="Index">Back to List</a>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
